    "emit-layout-only": "Changes emitted bytes or output layout; first-slice target selection follows source specifiers and explicit package fields, and an unresolved emitted package target remains incomplete.",
    "inventory-owned-source-set": "TypeScript source inclusion is not consulted because the versioned Lumin scan policy is the sole source-set owner.",
    "external-library-only": "Changes ambient/default-library type checking only; no first-slice compiler oracle or implicit ambient consumer is claimed.",
    "tooling-metadata-only": "Metadata is retained but is not consumed by the first-slice resolver.",
    "compiler-validation-only": "Changes compiler validation or deprecated compatibility behavior without changing a first-slice resolver input."
  },
