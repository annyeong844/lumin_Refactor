  "resolverRules": {
    "extends": {
      "supported": "one string naming a root-contained relative config or a discovered workspace package config",
      "workspacePackageConfig": {
        "packageSelection": "consume one exact inventory-owned workspace package mapping; duplicate or unsupported package identity remains inventory-owned PackageIdentityUnsupported, prevents config selection, and is never renamed or resolved by source order",
        "field": "package.json#tsconfig",
        "fieldShape": "one nonempty Unicode-scalar string",
        "fallback": "use package-root/tsconfig.json only when the tsconfig field is absent",
        "target": "resolve the selected field relative to the package root as a root-contained regular config file",
        "semanticInputs": "the selected package manifest and selected config target are owner-declared SemanticInputDemand values and are reserved before capture or consumption",
        "failure": "empty or malformed field, missing target, unsupported package lookup, physical or lexical root escape, cycle, or unreadable target is TsconfigSemanticsUnsupported; unsupported package identity propagates its inventory-owned limitation",
        "goldenVectors": [
          {"id": "custom-field", "packageJson": {"name": "@acme/tsconfig", "tsconfig": "configs/base.json"}, "selected": "configs/base.json"},
          {"id": "field-absent-fallback", "packageJson": {"name": "@acme/tsconfig"}, "selected": "tsconfig.json"},
          {"id": "empty-field", "packageJson": {"name": "@acme/tsconfig", "tsconfig": ""}, "result": "TsconfigSemanticsUnsupported"},
          {"id": "escape-field", "packageJson": {"name": "@acme/tsconfig", "tsconfig": "../base.json"}, "result": "TsconfigSemanticsUnsupported"}
        ]
      },
      "unsupported": "arrays, external-package lookup, cycles, root escape, and project-reference redirection"
    },
    "baseUrl": {
      "supported": "one root-contained string resolved relative to the declaring config"
    },
    "paths": {
      "supportedShape": "object<string,array<string>> with nonempty arrays; each key has zero or one star and each target has zero or one corresponding star",
      "precedence": "exact key, then longest literal wildcard prefix, then source declaration order",
      "unsupported": "empty target arrays, multiple stars, non-string targets, root escape, and any other nested shape"
    },
    "moduleResolution": {
      "supportedValues": ["bundler", "node", "node10", "node16", "nodenext"],
      "normalization": {"node10": "node"},
      "unsupported": "classic and every value outside supportedValues"
    },
    "moduleByResolutionProfile": {
      "node": ["commonjs"],
      "bundler": ["preserve", "es2015", "es2020", "es2022", "esnext"],
      "node16": ["node16"],
      "nodenext": ["nodenext"]
    },
    "moduleDefaultByResolutionProfile": {
      "node": "commonjs",
      "bundler": "preserve",
      "node16": "node16",
      "nodenext": "nodenext"
    },
    "unsupportedModulePair": "TsconfigSemanticsUnsupported",
    "packageFeatureByResolutionProfile": {
      "node": {
        "exports": "disabled",
        "imports": "disabled",
        "valueConditions": [],
        "typeConditions": [],
        "fallback": "legacy main and declaration-entry rules"
      },
      "bundler": {
        "exports": "enabled-modeled",
        "imports": "enabled-unsupported",
        "valueConditions": ["import"],
        "typeConditions": ["types", "import"],
        "excludedConditions": ["node", "require"],
        "fallback": "bundler package-entry rules"
      },
      "node16-import": {
        "exports": "enabled-modeled",
        "imports": "enabled-unsupported",
        "valueConditions": ["node", "import"],
        "typeConditions": ["node", "types", "import"]
      },
      "node16-require": {
        "exports": "enabled-modeled",
        "imports": "enabled-unsupported",
        "valueConditions": ["node", "require"],
        "typeConditions": ["node", "types", "require"]
      },
      "nodenext-import": {
        "exports": "enabled-modeled",
        "imports": "enabled-unsupported",
        "valueConditions": ["node", "import"],
        "typeConditions": ["node", "types", "import"]
      },
